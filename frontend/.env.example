# Yapı Frontend — Environment Variables (Section 8.4)
# Copy to .env. Only VITE_-prefixed vars are exposed to the browser bundle.
# NEVER place SUPABASE_SERVICE_KEY or ANTHROPIC_API_KEY here.

VITE_API_URL=https://yapi-code-production.up.railway.app/api/v1
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=        # Public client key — legacy anon key OR new sb_publishable_... (never the secret key)
VITE_REQUIRE_DIRECTOR_MFA=0    # CR-002-I: set to 1 to force directors through 2FA setup (requires Supabase MFA enabled)
