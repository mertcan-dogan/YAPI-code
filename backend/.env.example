# Yapı Backend — Environment Variables (Section 8.4)
# Copy to .env and fill values. NEVER commit the real .env.

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=        # Service/secret key (legacy service_role OR new sb_secret_...) — backend only

# Database (PostgreSQL connection string, SQLAlchemy + psycopg driver)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/yapi

# Auth / JWT
# Two verification modes are supported automatically, chosen by the token's alg:
#   - Legacy HS256 access tokens  -> verified with JWT_SECRET below.
#   - New asymmetric (ES256/RS256) -> verified via the project JWKS endpoint.
JWT_SECRET=                  # Legacy Supabase JWT secret (HS256). Leave blank if fully on signing keys.
SUPABASE_JWKS_URL=           # Optional. Defaults to {SUPABASE_URL}/auth/v1/.well-known/jwks.json

# AI
ANTHROPIC_API_KEY=           # Claude API key — backend only

# Email
RESEND_API_KEY=

# App config
FRONTEND_URL=http://localhost:5173   # CORS allowed origin
ENVIRONMENT=development              # development / staging / production

# Observability — error monitoring (Sentry). Leave SENTRY_DSN blank to fully
# disable Sentry (no data leaves the process). Errors-only: no tracing/profiling,
# send_default_pii=False, request bodies + sensitive fields stripped before send.
SENTRY_DSN=                          # Python project DSN from sentry.io (backend only)

# Security (CR-002-I)
ENCRYPTION_KEY=                      # passphrase for at-rest field encryption (backend only)
REQUIRE_DIRECTOR_MFA=false           # enforce 2FA for director role (via token AAL claim)
